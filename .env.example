# Copy this file to .env and fill in the keys you actually have.
# Anything left blank simply disables that platform/provider — the app degrades gracefully.

PORT=8787

# ---------- Reddit (official OAuth API, free personal-use tier) ----------
# Create at https://www.reddit.com/prefs/apps -> "create app" -> type "script"
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=signal-console/1.0 (personal research tool)

# ---------- Serper.dev (Google SERP API) ----------
# https://serper.dev — used for General Web, University Research, and compliant
# discovery snippets for X / LinkedIn / Facebook / Craigslist (queries Google, not the platform)
SERPER_API_KEY=
SERPER_MONTHLY_BUDGET=1500

# ---------- Firecrawl (on-demand full-page fetch, only when you click "expand") ----------
# https://firecrawl.dev
FIRECRAWL_API_KEY=
FIRECRAWL_MONTHLY_BUDGET=600

# ---------- ScraperAPI (fallback fetcher if Firecrawl fails/is exhausted) ----------
# https://scraperapi.com
SCRAPERAPI_API_KEY=
SCRAPERAPI_MONTHLY_BUDGET=400

# ---------- ScrapingBot (second fallback fetcher) ----------
# https://scraping-bot.io
SCRAPINGBOT_USER=
SCRAPINGBOT_API_KEY=
SCRAPINGBOT_MONTHLY_BUDGET=0

# ---------- ProxyScrape (OFF by default — see README "Craigslist & risk" section before enabling) ----------
PROXYSCRAPE_API_KEY=
PROXYSCRAPE_MONTHLY_BUDGET=0
ENABLE_PROXYSCRAPE=false

# ---------- Bright Data (OFF by default — reserved for later, see README) ----------
BRIGHTDATA_API_KEY=
BRIGHTDATA_MONTHLY_BUDGET=0
ENABLE_BRIGHTDATA=false

# Set to false to disable on-demand Craigslist "expand" fetches entirely (discovery/search still works)
ENABLE_CRAIGSLIST_FETCH=true

# ---------- Discord bot ----------
# https://discord.com/developers/applications -> New Application -> Bot
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
